generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

enum DonationType {
  CLUB
  CAMPAIGN
  EVENT
  CUSTOM
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PostType {
  UPDATE
  SUCCESS_STORY
}

model Profile {
  id         String   @id @db.Uuid
  full_name  String?
  avatar_url String?
  phone      String?
  bio        String?
  created_at DateTime @default(now())

  // Relations
  user_roles     UserRole[]
  posts          Post[]
  events         Event[]            @relation("EventCreator")
  donations      Donation[]
  participations EventParticipant[]
  announcements  Announcement[]
  gallery        Gallery[]
  custom_causes  CustomCause[]      @relation("CauseCreator")

  success_stories SuccessStory[]
  audit_logs      AuditLog[]
}

model Role {
  id   String @id @default(uuid()) @db.Uuid
  name String @unique

  user_roles UserRole[]
}

model UserRole {
  user_id     String   @db.Uuid
  role_id     String   @db.Uuid
  assigned_at DateTime @default(now())

  // Relations
  user Profile @relation(fields: [user_id], references: [id])
  role Role    @relation(fields: [role_id], references: [id])

  @@id([user_id, role_id])
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  title       String
  description String?
  location    String?
  event_date  DateTime
  status      String   @default("UPCOMING")

  is_donation_enabled Boolean  @default(false)
  goal_amount         Decimal? @db.Decimal(10, 2)
  raised_amount       Decimal  @default(0) @db.Decimal(10, 2)

  meta_title       String?
  meta_description String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  created_by String  @db.Uuid
  creator    Profile @relation("EventCreator", fields: [created_by], references: [id])

  participants EventParticipant[]
  donations    Donation[]

  @@index([event_date])
  @@index([status])
  @@index([created_at])
}

model EventParticipant {
  user_id    String   @db.Uuid
  event_id   String   @db.Uuid
  status     String   @default("JOINED")
  created_at DateTime @default(now())

  user  Profile @relation(fields: [user_id], references: [id])
  event Event   @relation(fields: [event_id], references: [id])

  @@id([user_id, event_id])
}

model Campaign {
  id          String  @id @default(uuid()) @db.Uuid
  title       String
  description String?

  is_donation_enabled Boolean @default(true)
  goal_amount         Decimal @db.Decimal(10, 2) // Fixed precision
  raised_amount       Decimal @default(0) @db.Decimal(10, 2) // Fixed precision

  start_date DateTime?
  end_date   DateTime?
  image_url  String?
  status     String

  meta_title       String?
  meta_description String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  donations Donation[]

  @@index([status])
  @@index([start_date])
  @@index([end_date])
  @@index([created_at])
}

model CustomCause {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  goal_amount   Decimal? @db.Decimal(10, 2)
  raised_amount Decimal  @default(0) @db.Decimal(10, 2)
  is_active     Boolean  @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  created_by String  @db.Uuid
  creator    Profile @relation("CauseCreator", fields: [created_by], references: [id])

  donations Donation[]

  @@index([is_active])
}

model Donation {
  id            String       @id @default(uuid()) @db.Uuid
  donation_type DonationType

  amount         Decimal       @db.Decimal(10, 2) // Fixed precision
  method         String
  transaction_id String?       @unique
  status         PaymentStatus @default(COMPLETED)

  is_anonymous Boolean @default(false)
  donor_name   String?
  donor_email  String?
  donor_phone  String?

  user_id         String? @db.Uuid
  eventId         String? @db.Uuid
  campaign_id     String? @db.Uuid
  custom_cause_id String? @db.Uuid

  user         Profile?     @relation(fields: [user_id], references: [id])
  campaign     Campaign?    @relation(fields: [campaign_id], references: [id])
  event        Event?       @relation(fields: [eventId], references: [id])
  custom_cause CustomCause? @relation(fields: [custom_cause_id], references: [id])

  created_at DateTime @default(now())

  @@index([donation_type])
  @@index([status])
  @@index([created_at])
}

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  post_type PostType @default(UPDATE)

  title   String?
  content String  @db.Text

  media Json?

  is_gallery_synced Boolean @default(false)
  likes_count       Int     @default(0)

  meta_title       String?
  meta_description String?
  status           String   @default("PUBLISHED")
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  author_id String  @db.Uuid
  author    Profile @relation(fields: [author_id], references: [id])
}

model Announcement {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  message    String
  created_at DateTime @default(now())

  created_by String  @db.Uuid
  creator    Profile @relation(fields: [created_by], references: [id])
}

model Gallery {
  id         String   @id @default(uuid()) @db.Uuid
  image_url  String
  caption    String?
  created_at DateTime @default(now())

  uploaded_by String  @db.Uuid
  uploader    Profile @relation(fields: [uploaded_by], references: [id])
}

model SuccessStory {
  id        String  @id @default(uuid()) @db.Uuid
  title     String
  content   String
  image_url String?
  status    String  @default("PUBLISHED")

  meta_title       String?
  meta_description String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  author_id String  @db.Uuid
  author    Profile @relation(fields: [author_id], references: [id])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  action     String
  entity     String
  entity_id  String   @db.Uuid
  details    Json?
  ip_address String?
  created_at DateTime @default(now())

  user_id String?  @db.Uuid
  user    Profile? @relation(fields: [user_id], references: [id])
}
